{
  "name": "claude-gombwe",
  "version": "0.1.7",
  "description": "Autonomous agent control panel powered by Claude Code — orchestrate AI tasks, triggers, workflows, and skills from anywhere",
  "type": "module",
  "bin": {
    "gombwe": "./dist/index.js"
  },
  "files": [
    "dist",
    "ui",
    "skills",
    "scripts",
    "agents",
    "README.md"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai-agent",
    "autonomous",
    "discord",
    "telegram",
    "automation",
    "mcp",
    "workflows",
    "anthropic"
  ],
  "author": "Tendai Mudavanhu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tech-ten/claude-gombwe.git"
  },
  "homepage": "https://github.com/tech-ten/claude-gombwe",
  "scripts": {
    "clean": "shx rm -rf dist && shx mkdir dist",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "dev": "run-p watch-server watch-assets",
    "watch-server": "tsx watch src/index.ts",
    "watch-assets": "shx echo 'Watching assets...'",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "croner": "^9.1.0",
    "discord.js": "^14.18.0",
    "express": "^5.1.0",
    "glob": "^11.0.0",
    "grammy": "^1.35.0",
    "gray-matter": "^4.0.3",
    "puppeteer-core": "^24.40.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.0",
    "cross-env": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "shx": "^0.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
